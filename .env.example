NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never prefix this key with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=
ATTENDANCE_QR_SECRET=
# Leave blank on Vercel so the app uses its same-origin /api routes.
NEXT_PUBLIC_API_URL=
# Prisma uses DATABASE_URL. On Vercel, set DATABASE_URL or connect Vercel Postgres
# and the app will also fall back to POSTGRES_PRISMA_URL / POSTGRES_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitsaathi?schema=public
POSTGRES_PRISMA_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-random-secret
FRONTEND_ORIGIN=http://localhost:3000
UPLOAD_PATH=./server/uploads
PRIVATE_UPLOAD_PATH=./server/private
# Required for provider uploads on Vercel. Connect one private Vercel Blob
# store to the project; keep these values server-only (never NEXT_PUBLIC_*).
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Keep the server and browser flags identical. When false, dojo Aadhaar fields
# are not requested; coach identity verification remains required.
ENABLE_AADHAAR_VERIFICATION=false
NEXT_PUBLIC_ENABLE_AADHAAR_VERIFICATION=false
